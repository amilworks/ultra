# Environment configuration
# Copy this file to .env and update values for your local development environment.
# Leave unset to default query-param auth compatibility to on in development and off in production.
ALLOW_QUERY_API_KEY_COMPAT=
# For production, use deploy/env/ultra-backend.env.example and deploy/env/platform.env.example
# as server-side EnvironmentFile templates instead of deploying one monolithic repo .env.

# Application
APP_NAME=Bisque Ultra
APP_VERSION=0.1.0
ENVIRONMENT=production
DEBUG=false

# Server
UI_SHOW_DIAGNOSTICS_DEFAULT=false
UI_AUTO_REPRO_REPORT=false
UI_FORCE_TOOL_VISUALIZATIONS=true
BISQUE_ENABLE_STREAMLIT_RUNTIME_BRIDGE=false

# Logging
LOG_LEVEL=INFO

# Security
ENABLE_CORS=false
ALLOWED_ORIGINS=[]

# Performance
MAX_UPLOAD_SIZE=200

# LLM provider routing (centralized)
# Supported providers: vllm, openai, ollama
LLM_PROVIDER=vllm
LLM_BASE_URL=
LLM_API_KEY=
LLM_MODEL=
# Response verbosity: concise | balanced | detailed
LLM_RESPONSE_VERBOSITY=detailed
LLM_MOCK_MODE=false

# Optional coding-model override (used only by codegen_python_plan)
CODEGEN_PROVIDER=
CODEGEN_BASE_URL=
CODEGEN_API_KEY=
CODEGEN_MODEL=
CODEGEN_TIMEOUT_SECONDS=

# Optional Pro Mode frontier-model override.
# Use `openai_compatible` for OpenAI/vLLM-style gateways, `bedrock_published_api` for
# API Gateway publishes that expose `/conversation`, and `aws_bedrock_claude` for
# Agno's native AWS Bedrock Claude transport.
PRO_MODE_TRANSPORT=openai_compatible
# For API Gateway protected publishes, set PRO_MODE_API_KEY_HEADER=X-API-Key and leave
# PRO_MODE_API_KEY_PREFIX blank so the key is sent as a raw x-api-key header.
PRO_MODE_BASE_URL=
PRO_MODE_API_KEY=
PRO_MODE_API_KEY_HEADER=
PRO_MODE_API_KEY_PREFIX=
PRO_MODE_MODEL=
PRO_MODE_DEFAULT_HEADERS={}
PRO_MODE_DEFAULT_QUERY={}
PRO_MODE_TIMEOUT_SECONDS=
PRO_MODE_FALLBACK_ENABLED=true
# Native AWS Bedrock Claude transport:
# - Prefer AWS_PROFILE/AWS_REGION in your shell for local testing, or set the
#   dedicated PRO_MODE_AWS_* values below.
# - Use one native auth strategy: PRO_MODE_AWS_BEARER_TOKEN, AWS profile/SSO, or
#   AWS access keys. Do not reuse API Gateway X-API-Key publish tokens here.
# - PRO_MODE_MODEL must be the Bedrock model identifier, not the published API alias.
#   Example: anthropic.claude-opus-4-5-20251101-v1:0
PRO_MODE_AWS_REGION=
PRO_MODE_AWS_PROFILE=
PRO_MODE_AWS_ACCESS_KEY_ID=
PRO_MODE_AWS_SECRET_ACCESS_KEY=
PRO_MODE_AWS_SESSION_TOKEN=
PRO_MODE_AWS_BEARER_TOKEN=
PRO_MODE_AWS_SSO_AUTH=false

# Provider defaults/fallbacks
# BisQue Ultra speaks to OpenAI-compatible endpoints. For local vLLM, point this at
# the vLLM server, usually on a different port than the FastAPI app.
OPENAI_API_KEY=
OPENAI_BASE_URL=http://localhost:8001/v1
OPENAI_MODEL=gpt-oss-120b
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=qwen2.5:14b-instruct
OPENAI_TIMEOUT=60
OPENAI_MAX_RETRIES=2

# Optional medical-domain routing
# When AGENTS_MEDICAL_BASE_URL is set, only the medical specialist can route to that endpoint.
# If the medical endpoint is unavailable, the runtime falls back to the global model path.
AGENTS_MODEL_MEDICAL=
AGENTS_MEDICAL_BASE_URL=
AGENTS_MEDICAL_API_KEY=
AGENTS_MEDICAL_TIMEOUT_SECONDS=60
AGENTS_MEDICAL_CIRCUIT_BREAKER_COOLDOWN_SECONDS=60
AGENTS_MEDICAL_MULTIMODAL_ENABLED=true
AGENTS_MEDICAL_MAX_IMAGES_PER_PROMPT=3
AGENTS_MEDICAL_MAX_INLINE_IMAGE_BYTES=1500000

# Optional Megaseg runtime overrides
MEGASEG_PYTHON=
CYTODL_PYTHON=
MEGASEG_CHECKPOINT_PATH=
MEGASEG_BENCHMARK_ROOT=
MEGASEG_SERVICE_URL=
MEGASEG_SERVICE_API_KEY=
MEGASEG_SERVICE_TIMEOUT_SECONDS=60
MEGASEG_SERVICE_POLL_INTERVAL_SECONDS=2
MEGASEG_SERVICE_WAIT_TIMEOUT_SECONDS=7200
MEGASEG_SERVICE_DOWNLOAD_ARTIFACTS=true

YOLO_DEFAULT_MODEL=data/models/yolo/yolo26x.pt
YOLOV5_RUNTIME_PATH=third_party/yolov5
YOLOV5_RARESPOT_WEIGHTS=data/models/yolo/RareSpotWeights.pt
PRAIRIE_ACTIVE_LEARNING_DATASET_NAME=Prairie_Dog_Active_Learning
PRAIRIE_SYNC_INTERVAL_SECONDS=21600
PRAIRIE_FIXED_EPOCHS=20
PRAIRIE_FIXED_BATCH_SIZE=4
PRAIRIE_FIXED_IMGSZ=1280
PRAIRIE_FIXED_CONF_THRESHOLD=0.25
PRAIRIE_FIXED_IOU_THRESHOLD=0.45
PRAIRIE_RETRAIN_MIN_REVIEWED_SAMPLES=25

# Postgres (local production-like testing)
COMPOSE_PROJECT_NAME=bisque-legacy
POSTGRES_HOST=localhost
POSTGRES_PORT=55432
BISQUE_POSTGRES_PORT=55433
POSTGRES_DB=bisque_ultra
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# Run + artifact storage
ORCHESTRATOR_API_URL=http://localhost:8000
ORCHESTRATOR_API_TIMEOUT=1800
ORCHESTRATOR_API_KEY=
# Primary run-store backend (Postgres-first)
RUN_STORE_PATH=postgresql://postgres:postgres@localhost:55432/bisque_ultra
# Optional: DSN used by Postgres integration tests (`make test-postgres-store`)
RUN_STORE_POSTGRES_TEST_DSN=postgresql://postgres:postgres@localhost:55432/bisque_ultra_test
# Optional SQLite fallback for local emergency recovery only:
# RUN_STORE_PATH=data/runs.db
ARTIFACT_ROOT=data/artifacts
SESSION_UPLOAD_ROOT=data/sessions
SCIENCE_DATA_ROOT=data/science
UPLOAD_STORE_ROOT=data/uploads
UPLOAD_MAX_FILES_PER_REQUEST=64
UPLOAD_MAX_FILE_SIZE_MB=2048
UPLOAD_VIEWER_MAX_DIMENSION=2048
VIEWER_HDF5_ENABLED=true
VIEWER_HDF5_ATLAS_MAX_VOXELS=16777216
VIEWER_HDF5_ATLAS_MAX_TEXTURE_MB=16
# LLM-authored Python code execution
CODE_EXECUTION_ENABLED=false
CODE_EXECUTION_DEFAULT_BACKEND=docker
CODE_EXECUTION_DURABLE_DEFAULT=true
CODE_EXECUTION_DEFAULT_TIMEOUT_SECONDS=900
CODE_EXECUTION_MAX_TIMEOUT_SECONDS=3600
CODE_EXECUTION_DEFAULT_CPU_LIMIT=2.0
CODE_EXECUTION_DEFAULT_MEMORY_MB=4096
CODE_EXECUTION_DOCKER_IMAGE=bisque-ultra-codeexec:py311
CODE_EXECUTION_DOCKER_NETWORK=none
CODE_EXECUTION_MAX_REPAIR_CYCLES=5
CODE_EXECUTION_MAX_TOTAL_TOOL_CALLS=12
CODE_EXECUTION_POLL_INTERVAL_SECONDS=1.0
TOOL_CALL_NAPKIN_ENABLED=true
TOOL_CALL_NAPKIN_PATH=.bisque/tool_call_memory.md
TOOL_CALL_NAPKIN_SKILL_PATH=SKILL.md
TOOL_CALL_NAPKIN_MAX_CONTEXT_CHARS=3200
# Prompt-scoped workpad pipeline controls (response-quality rollout)
PROMPT_WORKPAD_PIPELINE_ENABLED=false
PROMPT_WORKPAD_REFINEMENT_MODE=legacy
PROMPT_WORKPAD_RETAIN_ON_SUCCESS=false
PROMPT_WORKPAD_RETAIN_ON_FAILURE=true
# Adaptive phase-H output budget (used when PROMPT_WORKPAD_REFINEMENT_MODE=phased)
PROMPT_WORKPAD_PHASE_H_MIN_TOKENS=1400
PROMPT_WORKPAD_PHASE_H_MAX_TOKENS=6000
# Response quality scoring + one-pass repair thresholds
PROMPT_WORKPAD_QUALITY_REPAIR_ENABLED=true
PROMPT_WORKPAD_QUALITY_MAX_META_RATE=0.35
PROMPT_WORKPAD_QUALITY_MIN_COMPLETENESS=0.58
PROMPT_WORKPAD_QUALITY_MIN_NUMERIC_DENSITY=0.45

# OCR backend
OCR_BASE_URL=http://localhost:8000/v1
OCR_API_KEY=EMPTY
OCR_MODEL=deepseek-ai/DeepSeek-OCR
OCR_TIMEOUT=3600

# MedSAM2
MEDSAM2_MODEL_ID=latest
MEDSAM2_RUNTIME_ROOT=data/runtime/MedSAM2
MEDSAM2_CHECKPOINT_DIR=data/models/medsam2/checkpoints
MEDSAM2_DEFAULT_CHECKPOINT=MedSAM2_latest.pt
MEDSAM2_CONFIG_FILE=sam2.1_hiera_t512.yaml
MEDSAM2_MAX_SLICES=160

# SAM3
SAM3_MODEL_ID=data/models/sam3/facebook-sam3
SAM3_ALLOW_REMOTE_DOWNLOAD=false
SAM3_MAX_SLICES=192
SAM3_WINDOW_SIZE=1024
SAM3_WINDOW_OVERLAP=0.25
SAM3_MIN_POINTS=8
SAM3_MAX_POINTS=64
SAM3_POINT_DENSITY=0.0015
SAM3_MASK_THRESHOLD=0.5
SAM3_VOTE_THRESHOLD=0.5
SAM3_MIN_COMPONENT_AREA_RATIO=0.0001
SAM3_MODALITY_HINT=auto
SAM3_REFINE_3D=true
SAM3_FALLBACK_TO_MEDSAM2=true
SAM3_AUTO_ZERO_MASK_FALLBACK_ENABLED=true
SAM3_AUTO_ZERO_MASK_FALLBACK_PROMPT=object
SAM3_AUTO_ZERO_MASK_FALLBACK_PROMPTS=object,foreground,cell,nucleus
SAM3_AUTO_LOW_COVERAGE_FALLBACK_THRESHOLD_PERCENT=0.0
SEQUENCE_MAX_FRAMES_PER_FILE=24
SEQUENCE_FRAME_STRIDE=4

# DepthPro
DEPTH_PRO_MODEL_ID=apple/DepthPro-hf
DEPTH_PRO_USE_FOV_MODEL=true

# BisQue platform / app shared configuration
# These values drive both bisque_ultra and platform/bisque docker compose.
BISQUE_ROOT=http://localhost:8080
BISQUE_SERVER=http://localhost:8080
BISQUE_PORT=8080
BISQUE_USER=  # Your BisQue username
BISQUE_PASSWORD=  # Your BisQue password
BISQUE_ADMIN_EMAIL=admin@yourdomain.com
BISQUE_ADMIN_ID=admin
BISQUE_ORGANIZATION=Your Organization
BISQUE_TITLE=BisQue Image Repository
CONTAINER_NAME=bisque-server
IMAGE_TAG=bisque-ucsb:latest
BISQUE_DOCKER_PLATFORM=linux/amd64
NETWORK_NAME=bisque-network
# Auth mode shared with platform/bisque compose (local | oidc | dual).
BISQUE_AUTH_MODE=dual
# When true, login tries /auth_service/token first, then falls back to basic auth session checks.
BISQUE_AUTH_LOCAL_TOKEN_ENABLED=true
ADMIN_USERNAMES=
BISQUE_AUTH_SESSION_TTL_SECONDS=43200
ANONYMOUS_SESSION_TTL_SECONDS=2592000

# Optional: Keycloak / OIDC browser login
# Supports either BISQUE_AUTH_OIDC_* or BISQUE_OIDC_* variable names.
BISQUE_AUTH_OIDC_ENABLED=false
BISQUE_AUTH_OIDC_VIA_BISQUE_LOGIN=false
BISQUE_AUTH_OIDC_ISSUER_URL=
BISQUE_AUTH_OIDC_CLIENT_ID=
BISQUE_AUTH_OIDC_CLIENT_SECRET=
# Optional. If unset, backend derives callback from request host (fallback: ORCHESTRATOR_API_URL).
BISQUE_AUTH_OIDC_REDIRECT_URI=
BISQUE_AUTH_OIDC_FRONTEND_REDIRECT_URL=http://localhost:5173/
BISQUE_AUTH_OIDC_SCOPE=openid profile email
BISQUE_AUTH_OIDC_USERNAME_CLAIM=preferred_username
BISQUE_AUTH_OIDC_AUTHORIZE_URL=
BISQUE_AUTH_OIDC_TOKEN_URL=
BISQUE_AUTH_OIDC_USERINFO_URL=
BISQUE_AUTH_OIDC_LOGOUT_URL=
BISQUE_AUTH_LOGOUT_REDIRECT_URL=

# Local OIDC provider admin credentials (used by platform/bisque/docker-compose.oidc.yml)
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin
