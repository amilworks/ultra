# Private code execution service environment

# Filesystem/runtime
CODEEXEC_JOB_ROOT=/srv/ultra/codeexec-service/jobs
CODEEXEC_ARTIFACT_ROOT=/srv/ultra/codeexec-service/artifacts
CODEEXEC_WORKER_IMAGE=ultra-codeexec-job:current
CODEEXEC_DOCKER_NETWORK=none
CODEEXEC_MAX_CONCURRENT_JOBS=1

# Auth
CODEEXEC_API_KEY=replace-with-private-bearer-token

# Container / bind settings used by deploy/systemd/ultra-codeexec.service
CODEEXEC_SERVICE_BIND_ADDRESS=0.0.0.0
CODEEXEC_SERVICE_PORT=8020
