# Private Megaseg GPU service environment

# Filesystem/runtime
MEGASEG_CHECKPOINT_PATH=/srv/ultra/megaseg-service/models/megaseg/epoch_650.ckpt
MEGASEG_DEVICE=cuda
MEGASEG_JOB_ROOT=/srv/ultra/megaseg-service/jobs
MEGASEG_ARTIFACT_ROOT=/srv/ultra/megaseg-service/artifacts
MEGASEG_MAX_CONCURRENT_JOBS=1
MEGASEG_ENABLE_AMP=false

# Auth
MEGASEG_API_KEY=replace-with-private-bearer-token

# Container / bind settings used by deploy/systemd/ultra-megaseg.service
MEGASEG_SERVICE_BIND_ADDRESS=0.0.0.0
MEGASEG_SERVICE_PORT=8010
