# Server-side BisQue / Keycloak / Postgres environment
# Install as /etc/ultra/platform.env

# Platform data root for BisQue file storage on the shared barrel mount.
# Postgres and Keycloak state stay on local Docker volumes to avoid wedging the
# database on transient NFS stalls.
PLATFORM_DATA_ROOT=/mnt/barrel-data/ultra/platform
PLATFORM_DEPLOY_MODE=single-node

# Edge routing defaults. On a single-node setup these point at local services.
# In a split-node layout, point both at your platform node host:port.
AUTH_UPSTREAM=127.0.0.1:18080
BISQUE_UPSTREAM=127.0.0.1:8080

# Platform-node bind settings. For a shared split node, bind to the platform
# node's host IP and restrict access with host firewall rules.
PLATFORM_BIND_HOST=127.0.0.1
PLATFORM_PROXY_PORT=8088
PLATFORM_CADDYFILE=/etc/ultra/platform-node.Caddyfile
PLATFORM_DB_BIND_HOST=127.0.0.1
KEYCLOAK_REALM_IMPORT_FILE=/etc/ultra/keycloak-realm-bisque.json

# Single public hostname
BISQUE_PUBLIC_HOST=ultra.example.com
AUTH_PUBLIC_HOST=ultra.example.com
AUTH_PUBLIC_URL=https://ultra.example.com/auth
KEYCLOAK_HTTP_RELATIVE_PATH=/auth

# BisQue public-facing identity
BISQUE_ROOT=https://ultra.example.com
BISQUE_SERVER=https://ultra.example.com
BISQUE_BIND_HOST=0.0.0.0
BISQUE_PORT=8080
BISQUE_ENGINE_PORT=27000
BISQUE_AUTH_MODE=oidc
BISQUE_AUTH_LOCAL_TOKEN_ENABLED=false
BISQUE_AUTH_COOKIE_SECURE=true
BISQUE_BEAKER_SESSION_SECURE=true
BISQUE_BEAKER_SESSION_HTTPONLY=true
BISQUE_BEAKER_SESSION_SAMESITE=Lax
BISQUE_ADMIN_EMAIL=admin@example.com
BISQUE_ADMIN_ID=admin
BISQUE_ORGANIZATION="Your Organization"
BISQUE_TITLE="BisQue Image Repository"
BISQUE_DOCKER_PLATFORM=linux/amd64
NETWORK_NAME=bisque-network

# Shared Postgres host port. In a split-node layout this should stay private to
# the trusted platform network.
BISQUE_POSTGRES_PORT=55433
POSTGRES_PASSWORD=change-me-postgres-superuser

# Application databases created on first postgres bootstrap
BISQUE_DB_NAME=bisque
BISQUE_DB_USER=bisque
BISQUE_DB_PASSWORD=change-me-bisque-db
KEYCLOAK_DB_DATABASE=keycloak
KEYCLOAK_DB_USERNAME=keycloak
KEYCLOAK_DB_PASSWORD=change-me-keycloak-db
ULTRA_DB_DATABASE=ultra
ULTRA_DB_USERNAME=ultra
ULTRA_DB_PASSWORD=change-me-ultra-db

# BisQue service database URL
BISQUE_DBURL=postgresql://bisque:change-me-bisque-db@postgres:5432/bisque

# Keycloak admin bootstrap
KEYCLOAK_REALM_NAME=bisque
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=change-me-keycloak-admin
KEYCLOAK_PORT=18080
KEYCLOAK_HTTP_RELATIVE_PATH=/auth
# Internal admin URL used by deploy/keycloak/sync_keycloak_realm.py from inside the
# Keycloak container. Keep this aligned with KEYCLOAK_HTTP_RELATIVE_PATH.
KEYCLOAK_ADMIN_SERVER_URL=http://127.0.0.1:8080/auth

# BisQue platform OIDC client wiring through Keycloak under /auth on the same host.
# This is the BisQue browser client, not the Ultra API callback client.
BISQUE_OIDC_ISSUER=https://ultra.example.com/auth/realms/bisque
BISQUE_OIDC_METADATA_URL=http://keycloak:8080/auth/realms/bisque/.well-known/openid-configuration
BISQUE_OIDC_JWKS_URI=http://keycloak:8080/auth/realms/bisque/protocol/openid-connect/certs
BISQUE_OIDC_AUTHORIZATION_ENDPOINT=https://ultra.example.com/auth/realms/bisque/protocol/openid-connect/auth
BISQUE_OIDC_TOKEN_ENDPOINT=http://keycloak:8080/auth/realms/bisque/protocol/openid-connect/token
BISQUE_OIDC_END_SESSION_ENDPOINT=https://ultra.example.com/auth/realms/bisque/protocol/openid-connect/logout
BISQUE_OIDC_USERINFO_ENDPOINT=http://keycloak:8080/auth/realms/bisque/protocol/openid-connect/userinfo
BISQUE_OIDC_CLIENT_ID=bisque-web
BISQUE_OIDC_CLIENT_SECRET=change-me-bisque-oidc
BISQUE_OIDC_REDIRECT_URI=https://ultra.example.com/auth_service/oidc_callback
BISQUE_OIDC_POST_LOGOUT_REDIRECT_URI=https://ultra.example.com/client_service/
BISQUE_OIDC_SCOPES="openid profile email"
BISQUE_OIDC_USERNAME_CLAIM=preferred_username
BISQUE_OIDC_GROUPS_CLAIM=groups
BISQUE_OIDC_VERIFY_AUDIENCE=false
BISQUE_OIDC_AUTO_APPROVE_USERS=true
BISQUE_OIDC_LOGIN_PAGE_ENABLED=false
BISQUE_OIDC_PROVIDER_NAME=Keycloak
BISQUE_OIDC_LOGIN_BUTTON_TEXT="Continue with Keycloak"
# Keep direct access grants disabled for both BisQue and Ultra web clients unless
# you intentionally support resource-owner-password flows.
KEYCLOAK_CLIENT_DIRECT_ACCESS_GRANTS=false
KEYCLOAK_CLIENT_STANDARD_FLOW=true
KEYCLOAK_CLIENT_POST_LOGOUT_REDIRECT_URIS=https://ultra.example.com/*

# Optional explicit overrides for the Ultra web client provisioned alongside the
# BisQue client. In most deployments these are loaded from /etc/ultra/ultra-backend.env
# when scripts/deploy_platform_manual.sh renders and reconciles the realm.
# KEYCLOAK_ULTRA_CLIENT_REDIRECT_URIS=https://ultra.example.com/v1/auth/oidc/callback
# KEYCLOAK_ULTRA_CLIENT_WEB_ORIGINS=https://ultra.example.com
# KEYCLOAK_ULTRA_CLIENT_POST_LOGOUT_REDIRECT_URIS=https://ultra.example.com/*

# BisQue authenticated first-load traffic is bursty under the shared
# reverse-proxy setup, so production should use a larger SQLAlchemy pool than
# the legacy defaults.
BISQUE_SQLALCHEMY_POOL_RECYCLE=3600
BISQUE_SQLALCHEMY_POOL_PRE_PING=true
BISQUE_SQLALCHEMY_POOL_SIZE=25
BISQUE_SQLALCHEMY_MAX_OVERFLOW=25
BISQUE_SQLALCHEMY_POOL_TIMEOUT=60
