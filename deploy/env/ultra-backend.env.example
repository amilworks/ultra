# Server-side Ultra backend environment
# Install as /etc/ultra/ultra-backend.env

ENVIRONMENT=production
DEBUG=false
LOG_LEVEL=INFO

# Public routing
ULTRA_PUBLIC_HOST=ultra.ece.ucsb.edu
ULTRA_RELEASE_ROOT=/srv/ultra
ORCHESTRATOR_API_URL=https://ultra.ece.ucsb.edu
BISQUE_ROOT=https://bisque.example.com

# Shared local storage on the app node
RUN_STORE_PATH=postgresql://ultra:change-me-ultra-db@127.0.0.1:55433/ultra
ARTIFACT_ROOT=/srv/ultra/shared/artifacts
SESSION_UPLOAD_ROOT=/srv/ultra/shared/sessions
SCIENCE_DATA_ROOT=/srv/ultra/shared/science
UPLOAD_STORE_ROOT=/srv/ultra/shared/uploads

# Browser auth / OIDC
BISQUE_AUTH_OIDC_ENABLED=true
BISQUE_AUTH_OIDC_VIA_BISQUE_LOGIN=true
BISQUE_AUTH_OIDC_ISSUER_URL=https://auth.example.com/realms/bisque
BISQUE_AUTH_OIDC_CLIENT_ID=ultra-web
BISQUE_AUTH_OIDC_CLIENT_SECRET=change-me-ultra-oidc
BISQUE_AUTH_OIDC_REDIRECT_URI=https://ultra.ece.ucsb.edu/v1/auth/oidc/callback
BISQUE_AUTH_OIDC_FRONTEND_REDIRECT_URL=https://ultra.ece.ucsb.edu/
BISQUE_AUTH_OIDC_SCOPE=openid profile email
BISQUE_AUTH_OIDC_AUTHORIZE_URL=https://auth.example.com/realms/bisque/protocol/openid-connect/auth
BISQUE_AUTH_OIDC_TOKEN_URL=https://auth.example.com/realms/bisque/protocol/openid-connect/token
BISQUE_AUTH_OIDC_USERINFO_URL=https://auth.example.com/realms/bisque/protocol/openid-connect/userinfo
BISQUE_AUTH_OIDC_LOGOUT_URL=https://auth.example.com/realms/bisque/protocol/openid-connect/logout
BISQUE_AUTH_LOGOUT_REDIRECT_URL=https://ultra.ece.ucsb.edu/

# Model routing
LLM_PROVIDER=vllm
OPENAI_BASE_URL=http://10.0.2.50:8000/v1
OPENAI_MODEL=gpt-oss-120b
OPENAI_API_KEY=EMPTY

# Alternative Ollama example
# LLM_PROVIDER=ollama
# OLLAMA_BASE_URL=http://10.0.2.50:11434/v1
# OLLAMA_MODEL=qwen2.5:14b-instruct

# Optional code generation override
CODEGEN_PROVIDER=
CODEGEN_BASE_URL=
CODEGEN_MODEL=
CODEGEN_API_KEY=

# Recommended production defaults
UI_SHOW_DIAGNOSTICS_DEFAULT=false
UI_AUTO_REPRO_REPORT=false
UI_FORCE_TOOL_VISUALIZATIONS=true
ENABLE_CORS=false
ALLOWED_ORIGINS=[]
CODE_EXECUTION_ENABLED=true
