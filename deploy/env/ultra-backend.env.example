# Server-side Ultra backend environment
# Install as /etc/ultra/ultra-backend.env

ENVIRONMENT=production
DEBUG=false
LOG_LEVEL=INFO

# Public routing
ULTRA_PUBLIC_HOST=ultra.example.com
ACME_EMAIL=ops@example.com
ULTRA_RELEASE_ROOT=/srv/ultra
ORCHESTRATOR_API_URL=https://ultra.example.com
# Single-host production keeps BisQue on the same domain under its native root services.
BISQUE_ROOT=https://ultra.example.com

# In the split-node layout, keep the public host unchanged and point the run
# store at the platform node's private database bind.
PLATFORM_NODE_HOST=platform-node.internal

# Shared local storage on the app node
RUN_STORE_PATH=postgresql://ultra:change-me-ultra-db@platform-node.internal:55433/ultra
ARTIFACT_ROOT=/srv/ultra/shared/artifacts
SESSION_UPLOAD_ROOT=/srv/ultra/shared/sessions
SCIENCE_DATA_ROOT=/srv/ultra/shared/science
UPLOAD_STORE_ROOT=/srv/ultra/shared/uploads

# Browser auth / OIDC
# This is a separate Ultra web client in the same Keycloak realm. Keep the
# client ID/secret aligned with what platform deployment reconciles into Keycloak.
BISQUE_AUTH_MODE=oidc
BISQUE_AUTH_LOCAL_TOKEN_ENABLED=false
BISQUE_AUTH_OIDC_ENABLED=true
BISQUE_AUTH_OIDC_VIA_BISQUE_LOGIN=true
BISQUE_AUTH_OIDC_ISSUER_URL=https://ultra.example.com/auth/realms/bisque
BISQUE_AUTH_OIDC_CLIENT_ID=ultra-web
BISQUE_AUTH_OIDC_CLIENT_SECRET=change-me-ultra-oidc
BISQUE_AUTH_OIDC_REDIRECT_URI=https://ultra.example.com/v1/auth/oidc/callback
BISQUE_AUTH_OIDC_FRONTEND_REDIRECT_URL=https://ultra.example.com/
BISQUE_AUTH_OIDC_SCOPE="openid profile email"
BISQUE_AUTH_OIDC_AUTHORIZE_URL=https://ultra.example.com/auth/realms/bisque/protocol/openid-connect/auth
BISQUE_AUTH_OIDC_TOKEN_URL=https://ultra.example.com/auth/realms/bisque/protocol/openid-connect/token
BISQUE_AUTH_OIDC_USERINFO_URL=https://ultra.example.com/auth/realms/bisque/protocol/openid-connect/userinfo
BISQUE_AUTH_OIDC_LOGOUT_URL=https://ultra.example.com/auth/realms/bisque/protocol/openid-connect/logout
BISQUE_AUTH_LOGOUT_REDIRECT_URL=https://ultra.example.com/

# Model routing
LLM_PROVIDER=vllm
OPENAI_BASE_URL=http://model-node.internal:8000/v1
OPENAI_MODEL=gpt-oss-120b
OPENAI_API_KEY=EMPTY

# Alternative Ollama example
# LLM_PROVIDER=ollama
# OLLAMA_BASE_URL=http://model-node.internal:11434/v1
# OLLAMA_MODEL=qwen2.5:14b-instruct

# Optional code generation override
CODEGEN_PROVIDER=
CODEGEN_BASE_URL=
CODEGEN_MODEL=
CODEGEN_API_KEY=

# Recommended production defaults
UI_SHOW_DIAGNOSTICS_DEFAULT=false
UI_AUTO_REPRO_REPORT=false
UI_FORCE_TOOL_VISUALIZATIONS=true
ENABLE_CORS=false
ALLOWED_ORIGINS=[]
CODE_EXECUTION_ENABLED=true
