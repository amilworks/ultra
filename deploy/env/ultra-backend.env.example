# Server-side Ultra backend environment
# Install as /etc/ultra/ultra-backend.env

ENVIRONMENT=production
DEBUG=false
LOG_LEVEL=INFO

# Public routing
ULTRA_PUBLIC_HOST=ultra.example.com
ACME_EMAIL=ops@example.com
ULTRA_RELEASE_ROOT=/srv/ultra
ORCHESTRATOR_API_URL=https://ultra.example.com
# Single-host production keeps BisQue on the same domain under its native root services.
BISQUE_ROOT=https://ultra.example.com

# Shared local storage on the app node
# In a split-node deployment, replace 127.0.0.1 with the private database host
# from your operator inventory or private runbook.
RUN_STORE_PATH=postgresql://ultra:change-me-ultra-db@127.0.0.1:55433/ultra
ARTIFACT_ROOT=/srv/ultra/shared/artifacts
SESSION_UPLOAD_ROOT=/srv/ultra/shared/sessions
SCIENCE_DATA_ROOT=/srv/ultra/shared/science
UPLOAD_STORE_ROOT=/srv/ultra/shared/uploads

# Local science-model assets on the app node
YOLO_DEFAULT_MODEL=/srv/ultra/models/yolo/yolo26x.pt
YOLOV5_RARESPOT_WEIGHTS=/srv/ultra/models/yolo/RareSpotWeights.pt
MEDSAM2_RUNTIME_ROOT=/srv/ultra/runtime/MedSAM2
MEDSAM2_CHECKPOINT_DIR=/srv/ultra/models/medsam2/checkpoints
MEDSAM2_DEFAULT_CHECKPOINT=MedSAM2_latest.pt
SAM3_MODEL_ID=/srv/ultra/models/sam3/facebook-sam3
SAM3_ALLOW_REMOTE_DOWNLOAD=false

# Browser auth / OIDC
# This is a separate Ultra web client in the same Keycloak realm. Keep the
# client ID/secret aligned with what platform deployment reconciles into Keycloak.
BISQUE_AUTH_MODE=oidc
BISQUE_AUTH_LOCAL_TOKEN_ENABLED=false
BISQUE_AUTH_OIDC_ENABLED=true
BISQUE_AUTH_OIDC_VIA_BISQUE_LOGIN=true
BISQUE_AUTH_OIDC_ISSUER_URL=https://ultra.example.com/auth/realms/bisque
BISQUE_AUTH_OIDC_CLIENT_ID=ultra-web
BISQUE_AUTH_OIDC_CLIENT_SECRET=change-me-ultra-oidc
BISQUE_AUTH_OIDC_REDIRECT_URI=https://ultra.example.com/v1/auth/oidc/callback
BISQUE_AUTH_OIDC_FRONTEND_REDIRECT_URL=https://ultra.example.com/
BISQUE_AUTH_OIDC_SCOPE="openid profile email"
BISQUE_AUTH_OIDC_AUTHORIZE_URL=https://ultra.example.com/auth/realms/bisque/protocol/openid-connect/auth
BISQUE_AUTH_OIDC_TOKEN_URL=https://ultra.example.com/auth/realms/bisque/protocol/openid-connect/token
BISQUE_AUTH_OIDC_USERINFO_URL=https://ultra.example.com/auth/realms/bisque/protocol/openid-connect/userinfo
BISQUE_AUTH_OIDC_LOGOUT_URL=https://ultra.example.com/auth/realms/bisque/protocol/openid-connect/logout
BISQUE_AUTH_LOGOUT_REDIRECT_URL=https://ultra.example.com/

# Model routing
LLM_PROVIDER=vllm
# Replace 127.0.0.1 with your private inference host if the model server runs
# on a separate machine.
OPENAI_BASE_URL=http://127.0.0.1:8003/v1
OPENAI_MODEL=gpt-oss-120b
OPENAI_API_KEY=EMPTY

# Alternative Ollama example
# LLM_PROVIDER=ollama
# OLLAMA_BASE_URL=http://127.0.0.1:11434/v1
# OLLAMA_MODEL=qwen2.5:14b-instruct

# Optional code generation override
CODEGEN_PROVIDER=
CODEGEN_BASE_URL=
CODEGEN_MODEL=
CODEGEN_API_KEY=

# Optional Pro Mode frontier-model override.
# Use `openai_compatible` for OpenAI/vLLM-style gateways, `bedrock_published_api` for
# API Gateway publishes that expose `/conversation`, and `aws_bedrock_claude` for
# Agno's native AWS Bedrock Claude transport.
PRO_MODE_TRANSPORT=openai_compatible
# For API Gateway protected publishes, set PRO_MODE_API_KEY_HEADER=X-API-Key and leave
# PRO_MODE_API_KEY_PREFIX blank so the key is sent as a raw x-api-key header.
PRO_MODE_BASE_URL=
PRO_MODE_API_KEY=
PRO_MODE_API_KEY_HEADER=
PRO_MODE_API_KEY_PREFIX=
PRO_MODE_MODEL=
PRO_MODE_DEFAULT_HEADERS={}
PRO_MODE_DEFAULT_QUERY={}
PRO_MODE_TIMEOUT_SECONDS=
PRO_MODE_FALLBACK_ENABLED=true
# Native AWS Bedrock Claude transport:
# - Use one native auth strategy: PRO_MODE_AWS_BEARER_TOKEN, AWS profile/SSO, or
#   AWS access keys. Do not reuse API Gateway X-API-Key publish tokens here.
# - PRO_MODE_MODEL must be the Bedrock model identifier, not the published API alias.
#   Example: anthropic.claude-opus-4-5-20251101-v1:0
PRO_MODE_AWS_REGION=
PRO_MODE_AWS_PROFILE=
PRO_MODE_AWS_ACCESS_KEY_ID=
PRO_MODE_AWS_SECRET_ACCESS_KEY=
PRO_MODE_AWS_SESSION_TOKEN=
PRO_MODE_AWS_BEARER_TOKEN=
PRO_MODE_AWS_SSO_AUTH=false

# Optional Megaseg GPU service override
MEGASEG_SERVICE_URL=
MEGASEG_SERVICE_API_KEY=
MEGASEG_SERVICE_TIMEOUT_SECONDS=60
MEGASEG_SERVICE_POLL_INTERVAL_SECONDS=2
MEGASEG_SERVICE_WAIT_TIMEOUT_SECONDS=7200
MEGASEG_SERVICE_DOWNLOAD_ARTIFACTS=true

# Recommended production defaults
UI_SHOW_DIAGNOSTICS_DEFAULT=false
UI_AUTO_REPRO_REPORT=false
UI_FORCE_TOOL_VISUALIZATIONS=true
ENABLE_CORS=false
ALLOWED_ORIGINS=[]
CODE_EXECUTION_ENABLED=true
