# BisQue Docker Compose Environment Configuration
# In the bisque_ultra monorepo, the root `.env` / `.env.example` is the
# authoritative shared config for both the app and this compose file.
# Keep this file aligned with the root template if you run compose here directly.

# Server Configuration
BISQUE_SERVER=http://localhost:8080
BISQUE_PORT=8080

# Admin Configuration
BISQUE_ADMIN_EMAIL=admin@yourdomain.com
BISQUE_ADMIN_ID=admin
BISQUE_ORGANIZATION=Your Organization
BISQUE_TITLE=BisQue Image Repository

# Container Settings
COMPOSE_PROJECT_NAME=bisque-legacy
CONTAINER_NAME=bisque-server
IMAGE_TAG=bisque-ucsb:latest

# Network Settings
NETWORK_NAME=bisque-network
BISQUE_POSTGRES_PORT=55433

# Authentication mode: local | dual | oidc
BISQUE_AUTH_MODE=dual
# Optional override; defaults by mode (legacy/dual=true, oidc=false)
BISQUE_AUTH_LOCAL_TOKEN_ENABLED=true

# Local bearer token settings (used by /auth_service/token)
BISQUE_AUTH_TOKEN_ALGORITHM=HS256
BISQUE_AUTH_TOKEN_ISSUER=bisque
BISQUE_AUTH_TOKEN_AUDIENCE=bisque-api
BISQUE_AUTH_TOKEN_EXPIRY_SECONDS=3600
BISQUE_AUTH_TOKEN_CLOCK_SKEW_SECONDS=15
BISQUE_AUTH_TOKEN_VERIFY_AUDIENCE=false
# BISQUE_AUTH_TOKEN_SECRET=change-me

# OIDC settings (used in dual/oidc mode)
# For local docker-compose.oidc.yml, issuer should stay on localhost:18080
BISQUE_OIDC_ISSUER=http://localhost:18080/realms/bisque
BISQUE_OIDC_METADATA_URL=
BISQUE_OIDC_JWKS_URI=
BISQUE_OIDC_AUTHORIZATION_ENDPOINT=
BISQUE_OIDC_TOKEN_ENDPOINT=
BISQUE_OIDC_END_SESSION_ENDPOINT=
BISQUE_OIDC_USERINFO_ENDPOINT=
BISQUE_OIDC_CLIENT_ID=bisque-dev
BISQUE_OIDC_CLIENT_SECRET=bisque-dev-secret
BISQUE_OIDC_REDIRECT_URI=http://localhost:8080/auth_service/oidc_callback
BISQUE_OIDC_SCOPES=openid profile email
BISQUE_OIDC_USERNAME_CLAIM=preferred_username
BISQUE_OIDC_GROUPS_CLAIM=groups
BISQUE_OIDC_VERIFY_AUDIENCE=false
BISQUE_OIDC_AUTO_APPROVE_USERS=true

# Local OIDC provider (Keycloak) admin credentials
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin
